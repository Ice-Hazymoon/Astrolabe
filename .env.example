# Star Annotator API base URL.
# Defaults to http://localhost:3000 when unset.
# Leave empty / unset to use mock-only mode without any network calls.
# VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=https://constellate-api.imiku.me

# Public origin used for canonical URLs, OG tags, hreflang, sitemap, and JSON-LD.
# No trailing slash. Overridden per environment (preview deploys, production, etc.).
VITE_SITE_URL=https://stellaris.app

# Short product name used in OG site_name / structured data. Optional.
VITE_SITE_NAME=Stellaris
